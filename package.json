{
  "name": "pi-star-router",
  "version": "1.0.0",
  "description": "StarRouter is a focused model-routing extension for Pi. It chooses the best available model and thinking level for each prompt using a deterministic heuristic prompt profiler, Artificial Analysis benchmark data, provider-scoped model pools, strict model identity matching, and an explicit confirmation UI.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "test": "node --test --import tsx tests/*.test.ts",
    "smoke": "node tools/run-release-smoke-checks.js",
    "typecheck": "tsc --noEmit",
    "golden": "node --import tsx tools/run-router-golden-benchmark.js"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-star-router",
    "model-router",
    "artificial-analysis",
    "routing",
    "llm-routing",
    "pi"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "src",
